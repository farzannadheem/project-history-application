<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Project History Application" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Project History Application">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      /* Top navigation bar */
      .top-bar {
        # background-color: #2c3e50;
        # color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 20px;
        font-family: Arial, sans-serif;
      }

      .top-bar h1 {
        margin: 0;
        font-size: 24px;
      }

      .top-bar .user-info {
        display: flex;
        align-items: center;
      }

      .top-bar .user-info strong {
        margin-right: 15px;
      }

      .top-bar .logout-button {
        background-color: #e74c3c;
        border: none;
        padding: 6px 12px;
        color: white;
        cursor: pointer;
        border-radius: 4px;
        font-size: 14px;
      }

      .top-bar .logout-button:hover {
        background-color: #c0392b;
      }
    </style>
  </head>

  <body>
    <header class="top-bar">

      <% if user_signed_in? %>
      <h1>Project History Application</h1>
        <div class="user-info">
          Logged in as &nbsp; <strong><%= current_user.email %></strong>
          <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "logout-button" %>
        </div>
      <% end %>
    </header>

    <main style="padding: 20px;">
      <%= yield %>
    </main>
  </body>
</html>